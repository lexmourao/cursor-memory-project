# Copy to .env and adjust as required

# OpenAI configuration
# Leave blank to use fallback/manual behavior where supported.
OPENAI_API_KEY=

# Optional local API token protection
# Default is false so local-first development remains open.
# Set ENABLE_LOCAL_API_TOKEN=true and LOCAL_API_TOKEN=<your-token>
# when exposing protected routes outside trusted localhost usage.
ENABLE_LOCAL_API_TOKEN=false
LOCAL_API_TOKEN=

# Backend runtime configuration
SERVICE_NAME=cursor-memory-project
RUNTIME_MODE=local
MEMORY_BANK_DIR=memory-bank
HOST=127.0.0.1
PORT=7331

# Backup/encryption configuration
# Required only for encrypted backup workflows.
GPG_KEY_ID=
